# --- Tailwind Standalone CLI ---
# Ignores the renamed binaries for Windows, Mac, and Linux
tailwindcss
tailwindcss.exe

# Ignores the default downloaded filenames (e.g., tailwindcss-windows-x64.exe)
tailwindcss-*

# --- Build Output ---
dist/
output.css

# --- Node.js ---
# We ignore the contents of node_modules, but allow the lucide folder
node_modules/*
!node_modules/lucide/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Dependency directories
.pnp
.pnp.js

# Env files (usually contains secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Misc / OS Garbage ---
.DS_Store
Thumbs.db